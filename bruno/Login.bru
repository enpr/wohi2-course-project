meta {
  name: Login
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/auth/login
  body: json
  auth: inherit
}

params:query {
  ~email: admin@example.com
  ~password: 1234
}

body:json {
  {
    "email": "admin@example.com",
    "password": "1234"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
