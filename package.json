{
  "name": "backend-course-project",
  "version": "1.0.0",
  "description": "WOHI 2 project",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "db:migrate": "npx prisma migrate dev",
    "db:seed": "npx prisma db seed",
    "db:studio": "npx prisma studio",
    "db:reset": "npx prisma migrate reset",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:setup": "dotenv -e .env.test -- prisma migrate deploy",
    "test:coverage": "vitest run --coverage"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "keywords": [
    "express",
    "nodejs",
    "backend",
    "api"
  ],
  "license": "MIT",
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "pino": "^9.0.0",
    "pino-http": "^10.0.0",
    "zod": "^3.24.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.0.0",
    "dotenv-cli": "^8.0.0",
    "pino-pretty": "^13.0.0",
    "prisma": "^7.7.0",
    "supertest": "^7.0.0",
    "vitest": "^3.0.0"
  }
}
